<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HolaMundo.Maui.BarraDeProgreso.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
                Text="Hello, World!"
                Style="{StaticResource Headline}"                 />

            <Label
                Text="Simula una proceso de datos"
                Style="{StaticResource SubHeadline}"
                 />

            <Button
                x:Name="CounterBtn"
                Text="Procesar datos"                 
                Clicked="ClikedProcesarDatos"
                HorizontalOptions="Fill" />
            <ActivityIndicator x:Name="ActivityIndicator" IsVisible="Visible"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
