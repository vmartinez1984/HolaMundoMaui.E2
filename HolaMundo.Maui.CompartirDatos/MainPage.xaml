<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HolaMundo.Maui.CompartirDatos.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
                Text="Hello, World!"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Compartir Datos entre Páginas"
                Style="{StaticResource SubHeadline}"                
                 />

            <Button                
                Text="Ir a la pagina 1"                 
                Clicked="ClickedIrALaPagina1"
                HorizontalOptions="Fill" />

            <Button                
                  Text="Ir a la pagina 2"                 
                  Clicked="ClickedIrALaPagina2"
                  HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
